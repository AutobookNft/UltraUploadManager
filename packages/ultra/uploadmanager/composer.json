{
    "name": "ultra/uploadmanager",
    "description": "A modular upload manager for the Ultra ecosystem",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fabio Cherici",
            "email": "fabiocherici@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "*",
        "league/flysystem-aws-s3-v3": "^3.0",
        "pusher/pusher-php-server": "^7.2",
        "ultra/ultra-log-manager": "dev-main",
        "ultra/ultra-config-manager": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Ultra\\UploadManager\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ultra\\UploadManager\\UploadManagerServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/AutobookNft/UltraLogManager"
        },
        {
            "type": "vcs",
            "url": "https://github.com/AutobookNft/UltraConfigManager"
        }
    ]

}
